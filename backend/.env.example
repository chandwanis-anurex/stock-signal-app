# Database
DATABASE_URL=sqlite:///./app.db

# Market data provider (pick one: polygon | alpaca | twelvedata)
MARKET_DATA_PROVIDER=polygon
MARKET_DATA_API_KEY=your_polygon_or_provider_key

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SendGrid (Email)
SENDGRID_API_KEY=
ALERT_FROM_EMAIL=alerts@yourapp.com

# Firebase Cloud Messaging (Push)
FCM_SERVER_KEY=

# TradeStation (optional direct broker integration)
TRADESTATION_CLIENT_ID=
TRADESTATION_CLIENT_SECRET=
TRADESTATION_REDIRECT_URI=

# Scheduler
SCREENER_REFRESH_SECONDS=300
SIGNAL_CHECK_SECONDS=60
