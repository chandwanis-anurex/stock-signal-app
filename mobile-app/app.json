{
  "expo": {
    "name": "SignalFlow",
    "slug": "stock-signal-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.chandwanis.signalflow",
      "buildNumber": "1",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Not used",
        "NSMicrophoneUsageDescription": "Not used"
      }
    },
    "plugins": [
      "expo-notifications",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "704b6240-b34b-43ee-a76e-2be8ddade1e9"
      }
    },
    "owner": "rakeshchandwani"
  }
}
